<div class="flex items-center gap-[0.625rem] bg-white rounded-[0.625rem] py-[0.5rem] px-[1.25rem]" 
style="box-shadow: 0.625rem 0.625rem 1.25rem 0 rgba(11, 18, 38, 0.03); background: #fff;">

  <!-- ICON -->
  <div class="w-[2.5rem] h-[2.5rem] flex items-center justify-center">
    <svg class="w-[2.5rem] h-[2.5rem]">
      <use href="/icons/sprite/sprite.svg#{{iconId}}"></use>
    </svg>
  </div>

  <!-- RATING VALUE -->
  <div class="text-[1.875rem] font-semibold tracking-[-0.07em] text-[#0F172A]">
    {{rating}}
  </div>

  <!-- STARS + REVIEWS -->
  <div class="flex flex-col gap-[0.25rem] pl-[0.125rem]">

    <div class="flex items-center gap-[0.25rem]">

      {{#times starCount}}
        <svg class="w-[0.8125rem] h-[0.8125rem] text-yelow">
          <use href="/icons/sprite/sprite.svg#star"></use>
        </svg>
      {{/times}}

    </div>

    <!-- REVIEWS COUNT -->
    <div class="text-[0.8125rem] font-normal tracking-[-0.01em] text-[#6624D6]">
      {{reviews}}
    </div>

  </div>

</div>